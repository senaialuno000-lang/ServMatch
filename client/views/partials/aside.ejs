<aside class="sidebar">
  <div class="sidebar__brand">
    <span class="sidebar__brand-text">ServMatch</span>
  </div>

  <div class="sidebar__user">
    <div class="sidebar__avatar">
      <% if (user && user.foto) { %>
        <img src="<%= user.foto %>" alt="Foto de <%= user.nome %>" />
      <% } else { %>
        <div class="sidebar__avatar-placeholder"></div>
      <% } %>
    </div>
    <div class="sidebar__user-info">
      <span class="sidebar__user-name"><%= user ? user.nome : 'Usuário' %></span>
      <span class="sidebar__user-role"><%= user ? user.cargo : 'Desenvolvedor Back End' %></span>
    </div>
  </div>

  <nav class="sidebar__nav">
    <ul class="sidebar__nav-list">
      <li class="sidebar__nav-item">
        <a href="/home" class="sidebar__nav-link <%= currentPage === 'home' ? 'sidebar__nav-link--active' : '' %>">
          <svg class="sidebar__nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
            <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
          </svg>
          <span>Home</span>
        </a>
      </li>
      <li class="sidebar__nav-item">
        <a href="/minhas-vagas" class="sidebar__nav-link <%= currentPage === 'minhas-vagas' ? 'sidebar__nav-link--active' : '' %>">
          <svg class="sidebar__nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
          </svg>
          <span>Minhas Vagas</span>
        </a>
      </li>
    </ul>
  </nav>
</aside>
